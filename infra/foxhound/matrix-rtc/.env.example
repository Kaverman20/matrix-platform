# Copy to .env on the VPS and fill real values. Never commit the filled .env.
# These must match the keys block in livekit.yaml.
LIVEKIT_API_KEY=REPLACE_API_KEY
LIVEKIT_API_SECRET=REPLACE_API_SECRET

# Public wss URL of the LiveKit SFU (what clients connect to).
LIVEKIT_WS_URL=wss://matrix-rtc.foxhound.run
