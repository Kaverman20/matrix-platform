KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=example-realm
KEYCLOAK_CLIENT_ID=matrix-keycloak-sync
KEYCLOAK_CLIENT_SECRET=change-me

MATRIX_HOMESERVER_URL=https://matrix.foxhound.run
MATRIX_ACCESS_TOKEN=change-me
MATRIX_SERVER_NAME=matrix.foxhound.run
MATRIX_BOT_USERNAME=sync-bot

USE_FORCE_JOIN=true
REVOKE_ACCESS=true
SYNC_INTERVAL=300
MAPPING_FILE=mapping.yaml

# Источник правил: yaml (по умолчанию, читает MAPPING_FILE) или db (mapping-api).
# Переключать на db ТОЛЬКО после `python sync.py --import-yaml` (импорт текущего
# YAML в БД), иначе потеряются существующие выдачи. db требует DATABASE_URL.
RULES_SOURCE=yaml
DATABASE_URL=

# Optional safety gate. When set, users outside this Keycloak group can be deactivated.
GATE_GROUP=
DEACTIVATE_ON_GATE_LOSS=false
# Max accounts the gate may deactivate in a single run — a brake against mass
# deactivation from a bad Keycloak response. Raise only if a large batch is expected.
MAX_DEACTIVATIONS=10

